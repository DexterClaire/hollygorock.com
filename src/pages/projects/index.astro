---
import Base from '../../layouts/Base.astro';
---

<Base title="projects" description="Projects — hollygorock.com">
  <h1>// PROJECTS</h1>

  <div class="box intro-box">
    <div class="box-title">// DOS 6.2</div>
    <p class="bright lead">this is what i'm currently building. everything here is real, running, and probably held together with zip ties.</p>
    <p class="warning">⚠ vastly, greatly, majorly under construction. proof-of-concept only. do not adjust your set.</p>
  </div>

  <ul class="project-list">
    <li>
      <a href="/projects/speedrunning">&gt; speedrunning</a>
      <span class="muted"> — chasing times on the leaderboard</span>
    </li>
    <li>
      <a href="/projects/vinyl-scrobbler">&gt; vinyl scrobbler</a>
      <span class="muted"> — ambient audio recognition to last.fm</span>
    </li>
    <li>
      <a href="/projects/linuxplex">&gt; linuxplex</a>
      <span class="muted"> — self-hosting plex from my mom's trash pc</span>
    </li>
    <li>
      <a href="/projects/p25-radio">&gt; p25 scanner</a>
      <span class="muted"> — monitoring local public safety radio</span>
    </li>
    <li>
      <a href="/projects/nes-sequencer">&gt; nes 16-step sequencer</a>
      <span class="muted"> — step sequencer running on real NES hardware</span>
    </li>
    <li>
      <a href="/projects/pentium-mmx">&gt; pentium mmx build</a>
      <span class="muted"> — restoring a 1997 era desktop</span>
    </li>
  </ul>
</Base>

<style>
  .lead {
    font-size: 0.85rem;
    margin-bottom: 0.25rem;
  }

  .warning {
    color: var(--amber-dim);
    font-size: 0.85rem;
    margin-bottom: 0;
  }

  .project-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.9rem;
  }
</style>
