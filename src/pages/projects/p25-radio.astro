---
import Base from '../../layouts/Base.astro';
---

<Base title="p25 scanner" description="P25 radio scanner running on Raspberry Pi with OP25">
  <h1>// P25 SCANNER</h1>

  <div class="box">
    <div class="box-title">// STATUS</div>
    <table class="ident-table">
      <tr>
        <td class="label">status</td>
        <td class="status-active">● active</td>
      </tr>
      <tr>
        <td class="label">type</td>
        <td>hardware / radio / automation</td>
      </tr>
      <tr>
        <td class="label">platform</td>
        <td>Raspberry Pi</td>
      </tr>
      <tr>
        <td class="label">language</td>
        <td>Python</td>
      </tr>
    </table>
  </div>

  <div class="box">
    <div class="box-title">// WHAT IT DOES</div>
    <p>
      Monitors local public safety radio traffic using
      <a href="https://github.com/osmocom/op25" target="_blank" rel="noopener">OP25</a>,
      an open source P25 digital radio decoder. Runs on a Raspberry Pi.
    </p>
    <p>
      Physical switches and buttons send commands to OP25 over HTTP —
      channel changes, volume, trunk group control — without touching a keyboard.
      Status and channel info output to a small LCD screen.
    </p>
  </div>

  <a href="/projects" class="back">&lt; back to projects</a>
</Base>
