---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const entries = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const posts = await Promise.all(
  entries.map(async (entry) => ({
    slug: entry.id,
    data: entry.data,
    Content: (await render(entry)).Content,
  }))
);
---

<Base title="blog" description="Blog — hollygorock.com">
  <h1>// BLOG</h1>

  <div class="post-list">
    {posts.map(({ slug, data, Content }) => (
      <div class="box post-card">
        <div class="post-header">
          <a href={`/blog/${slug}`} class="post-title">&gt; {data.title}</a>
          {data.tag && <span class="tag">[{data.tag}]</span>}
          <span class="date">{data.date.toISOString().slice(0, 10)}</span>
        </div>
        <div class="prose">
          <Content />
        </div>
      </div>
    ))}
  </div>
</Base>

<style>
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .post-title {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--amber-glow);
    font-weight: 700;
  }

  .tag {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    color: var(--amber-dim);
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .date {
    font-size: 0.75rem;
    color: var(--muted);
    margin-left: auto;
  }

  .prose {
    font-size: 0.85rem;
    color: var(--amber-dim);
    line-height: 1.7;
  }

  .prose :global(p) {
    margin-bottom: 0.75rem;
    color: var(--amber-dim);
  }

  .prose :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
