---
import Base from '../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const entries = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const recentPosts = await Promise.all(
  entries.map(async (entry) => ({
    slug: entry.id,
    data: entry.data,
    Content: (await render(entry)).Content,
  }))
);
---

<Base title="home">
  <h1>// HOME</h1>

  <div class="box intro-box">
    <div class="box-title">// SYSTEM BOOT</div>
    <p class="bright lead">welcome to hollygorock.com</p>
    <p class="blurb">this is my brain. it contains music, speedruns, radio signals, half-finished projects, and information no one asked for. statistically speaking you are probably me. but if you're not — hi, hope you find something worth your time.</p>
  </div>

  <h2>// BLOG</h2>

  <div class="post-list">
    {recentPosts.map(({ slug, data, Content }) => (
      <div class="box post-card">
        <div class="post-header">
          <a href={`/blog/${slug}`} class="post-title">&gt; {data.title}</a>
          {data.tag && <span class="tag">[{data.tag}]</span>}
          <span class="date">{data.date.toISOString().slice(0, 10)}</span>
        </div>
        <div class="prose">
          <Content />
        </div>
      </div>
    ))}
    <a href="/blog" class="see-all muted">see all →</a>
  </div>

<div class="construction">
  <img src="/under-construction.gif" alt="under construction" />
</div></Base>

<style>
  .lead {
    font-size: 0.85rem;
    margin-bottom: 0.25rem;
  }

  .blurb {
    color: var(--amber-dim);
    font-size: 0.85rem;
    margin-bottom: 0;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .post-title {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--amber-glow);
    font-weight: 700;
  }

  .tag {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    color: var(--amber-dim);
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .date {
    font-size: 0.75rem;
    color: var(--muted);
    margin-left: auto;
  }

  .prose {
    font-size: 0.85rem;
    color: var(--amber-dim);
    line-height: 1.7;
  }

  .prose :global(p) {
    margin-bottom: 0.75rem;
    color: var(--amber-dim);
  }

  .prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .see-all {
    font-size: 0.8rem;
  }

  .construction {
    margin-top: 2.5rem;
    text-align: center;
  }
  .construction img {
    image-rendering: pixelated;
  }
</style>
