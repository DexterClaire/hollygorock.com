---
import Base from '../layouts/Base.astro';
---

<Base title="home">
  <div class="box">
    <div class="box-title">// SYSTEM BOOT</div>
    <p>
      welcome to hollygorock.com<br />
      <span class="muted">a node for music, gaming, radio, code, and other signals.</span>
    </p>
  </div>

  <div class="box">
    <div class="box-title">// STAND-IN</div>
    <p class="muted">
      something will go here. not sure what yet. check back later.
    </p>
  </div>

<div class="construction">
  <img src="/under-construction.gif" alt="under construction" />
</div></Base>

<style>
  .construction {
    margin-top: 2.5rem;
    text-align: center;
  }
  .construction img {
    image-rendering: pixelated;
  }
</style>
